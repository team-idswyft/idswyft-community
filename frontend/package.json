{
  "name": "idswyft-frontend",
  "version": "1.0.2",
  "description": "Frontend for Idswyft identity verification platform",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "generate:narration": "node scripts/generate-narration.mjs",
    "generate:keyboard-fx": "node scripts/generate-keyboard-fx.mjs",
    "generate:all-audio": "node scripts/generate-keyboard-fx.mjs && node scripts/generate-narration.mjs",
    "render:demo": "npx remotion render src/remotion/index.ts DeveloperIntegrationDemo out/developer-integration-demo.mp4 --props='{\"narration\":true}'"
  },
