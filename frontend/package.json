    "@noble/hashes": "^2.0.1",
    "@remotion/google-fonts": "^4.0.435",
    "@remotion/player": "^4.0.435",
    "@tanstack/react-query": "^5.8.4",
    "axios": "^1.15.0",
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3",
    "react-hook-form": "^7.47.0",
    "react-hot-toast": "^2.4.1",
