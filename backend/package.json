{
  "name": "idswyft-backend",
  "version": "1.8.40",
  "description": "Backend API for Idswyft identity verification platform",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "test": "vitest",
    "lint": "eslint src --ext .ts,.js",
    "type-check": "tsc --noEmit",
    "migrate": "tsx src/scripts/migrate.ts",
    "benchmark": "tsx scripts/benchmark/benchmark-ocr.ts --specimens-dir scripts/benchmark/specimens --output scripts/benchmark/benchmark-results.json",
    "railway:build": "npm run build",
    "railway:start": "npm run start"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/s3-request-presigner": "^3.1032.0",
    "@idswyft/shared": "*",
    "@noble/ed25519": "^3.1.0",
    "@sentry/node": "^10.49.0",
    "@sentry/profiling-node": "^10.49.0",
    "@supabase/supabase-js": "^2.103.3",
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "csrf-csrf": "^4.0.3",
    "did-jwt": "^8.0.18",
    "did-jwt-vc": "^4.0.16",
    "did-resolver": "^4.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.3.2",
    "file-type": "^22.0.1",
    "helmet": "^8.1.0",
    "image-size": "^2.0.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "mrz": "^5.0.2",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "otplib": "^13.4.0",
    "parse-usdl": "^3.2.0",
    "pg": "^8.20.0",
    "pixelmatch": "^7.1.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "uuid": "^13.0.0",
    "validator": "^13.15.35",
    "web-did-resolver": "^2.0.32",
    "winston": "^3.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/crypto-js": "^4.2.1",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/mrz": "^3.2.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^11.0.0",
    "@types/validator": "^13.15.10",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
